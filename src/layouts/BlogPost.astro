---
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import FormattedDate from '../components/FormattedDate.astro';
import Header from '../components/Header.astro';
import type { Lang } from '../config';
import type { Alternates } from '../i18n';

interface Props {
	title: string;
	description: string;
	pubDate: Date;
	updatedDate?: Date;
	lang: Lang;
	alternates: Alternates;
}

const { title, description, pubDate, updatedDate, lang, alternates } = Astro.props;
---

<html lang={lang === 'en' ? 'en' : 'zh-CN'}>
	<head>
		<BaseHead title={title} description={description} lang={lang} alternates={alternates} />
	</head>

	<body>
		<Header lang={lang} alternates={alternates} />
		<main>
			<article>
				<header class="post-header">
					<h1>{title}</h1>
					<div class="post-meta">
						<FormattedDate date={pubDate} lang={lang} />
						{
							updatedDate && (
								<span>
									{lang === 'zh' ? '更新于 ' : 'Updated '}
									<FormattedDate date={updatedDate} lang={lang} />
								</span>
							)
						}
					</div>
				</header>
				<div class="prose">
					<slot />
				</div>
			</article>
		</main>
		<Footer lang={lang} />
	</body>
</html>
