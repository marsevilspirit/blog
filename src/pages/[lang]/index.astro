---
import { getCollection } from 'astro:content';
import BaseHead from '../../components/BaseHead.astro';
import Footer from '../../components/Footer.astro';
import FormattedDate from '../../components/FormattedDate.astro';
import Header from '../../components/Header.astro';
import { AUTHOR_AVATAR, AUTHOR_LINKS, AUTHOR_NAME, LANGUAGES, SITE, SITE_TITLE, type Lang } from '../../config';
import { groupsForLang, postPath, postsPath, publishedPostGroups, rssPath, sitePageAlternates } from '../../i18n';
import { postExcerpt } from '../../post-excerpt';

export function getStaticPaths() {
	return LANGUAGES.map((lang) => ({
		params: { lang },
		props: { lang },
	}));
}

interface Props {
	lang: Lang;
}

const { lang } = Astro.props;
const copy = SITE[lang];
const alternates = sitePageAlternates('home');
const groups = groupsForLang(publishedPostGroups(await getCollection('posts')), lang).slice(0, 5);
const authorLinks = AUTHOR_LINKS.map((link) =>
	link.label === 'RSS' ? { ...link, href: rssPath(lang) } : link,
);
---

<!doctype html>
<html lang={copy.htmlLang}>
	<head>
		<BaseHead title={SITE_TITLE} description={copy.description} lang={lang} alternates={alternates} />
	</head>
	<body>
		<Header lang={lang} alternates={alternates} />
		<main>
			<section class="author-profile">
				<img class="author-avatar" src={AUTHOR_AVATAR} alt={AUTHOR_NAME} />
				<div>
					<h1>{SITE_TITLE}</h1>
					<p class="muted">{AUTHOR_NAME} · {copy.authorHeadline}</p>
					<p>{copy.authorBio}</p>
					<ul class="inline-links">
						{
							authorLinks.map((link) => (
								<li>
									<a href={link.href} target={link.href.startsWith('http') ? '_blank' : undefined}>
										{link.label}
									</a>
								</li>
							))
						}
					</ul>
				</div>
			</section>

			<section aria-labelledby="recent-posts">
				<h2 id="recent-posts">{copy.home.recentPosts}</h2>
				<ul class="post-list">
					{
						groups.map((group) => {
							const post = group.entries[lang]!;
							return (
								<li>
									<a href={postPath(lang, group.slug)}>{post.data.title}</a>
									<FormattedDate date={group.date} lang={lang} />
									<p>{postExcerpt(post.body, post.data.description)}</p>
								</li>
							);
						})
					}
				</ul>
				<p><a href={postsPath(lang)}>{copy.home.allPosts}</a></p>
			</section>
		</main>
		<Footer lang={lang} />
	</body>
</html>
