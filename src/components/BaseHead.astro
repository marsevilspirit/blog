---
// Import the global.css file here so that it is included on
// all pages through the use of the <BaseHead /> component.
import '../styles/global.css';
import { ClientRouter } from 'astro:transitions';
import { SITE_TITLE, type Lang } from '../config';
import { defaultAlternate, rssPath, type Alternates } from '../i18n';
import { Font } from 'astro:assets';

interface Props {
	title: string;
	description: string;
	lang: Lang;
	alternates?: Alternates;
}

const canonicalURL = new URL(Astro.url.pathname, Astro.site);

const { title, description, lang, alternates = {} } = Astro.props;
const xDefault = defaultAlternate(alternates);
---

<!-- Global Metadata -->
<meta charset="utf-8" />
<meta name="viewport" content="width=device-width,initial-scale=1" />
<link rel="icon" sizes="16x16" type="image/png" href="/favicon-16x16.png" />
<link rel="icon" sizes="32x32" type="image/png" href="/favicon-32x32.png" />
<link rel="icon" href="/favicon.ico" />
<link rel="apple-touch-icon" href="/apple-touch-icon.png" />
<link rel="manifest" href="/site.webmanifest" />
<link rel="sitemap" href="/sitemap-index.xml" />
<link
	rel="alternate"
	type="application/rss+xml"
	title={SITE_TITLE}
	href={new URL(rssPath(lang), Astro.site)}
/>
<meta name="generator" content={Astro.generator} />

<Font cssVariable="--font-atkinson" preload />
<ClientRouter />

<!-- Canonical URL -->
<link rel="canonical" href={canonicalURL} />
{
	Object.entries(alternates).map(([alternateLang, href]) => (
		<link rel="alternate" hreflang={alternateLang} href={new URL(href, Astro.site)} />
	))
}
{xDefault && <link rel="alternate" hreflang="x-default" href={new URL(xDefault, Astro.site)} />}

<!-- Primary Meta Tags -->
<title>{title}</title>
<meta name="title" content={title} />
<meta name="description" content={description} />

<!-- Open Graph / Facebook -->
<meta property="og:type" content="website" />
<meta property="og:url" content={Astro.url} />
<meta property="og:title" content={title} />
<meta property="og:description" content={description} />

<!-- Twitter -->
<meta property="twitter:card" content="summary" />
<meta property="twitter:url" content={Astro.url} />
<meta property="twitter:title" content={title} />
<meta property="twitter:description" content={description} />
