	},
	"devDependencies": {
		"@eslint/js": "^10.0.1",
		"eslint": "^10.4.1",
		"eslint-plugin-astro": "^1.7.0",
		"globals": "^17.6.0",
		"prettier": "^3.8.3",
		"prettier-plugin-astro": "^0.14.1",
		"typescript-eslint": "^8.60.1",
		"vitest": "^4.1.8"
