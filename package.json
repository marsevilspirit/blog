{
	"name": "blog",
	"type": "module",
	"version": "0.0.1",
	"packageManager": "pnpm@11.5.2",
	"engines": {
		"node": ">=26.3.0"
	},
	"scripts": {
		"dev": "astro dev",
		"build": "astro build",
		"preview": "astro preview",
		"astro": "astro",
		"lint": "eslint .",
		"format": "prettier --write .",
